[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-k": "outline::Toggle",
      "shift-5": "workspace::ToggleZoom",
    }
  },
  {
    "context": "GitPanel || ProjectPanel || CollabPanel || OutlinePanel || ChatPanel || VimControl || EmptyPane || SharedScreen || MarkdownPreview || KeyContextView || Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "shift-escape": null,
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "g d": "editor::GoToDefinition"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "g u i": "editor::GoToDefinition"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "g g d": "editor::GoToDefinitionSplit"
    }
  }
]
